# Server Configuration
PORT=3000

# JWT Configuration
JWT_SECRET=your_very_secure_random_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# SendGrid Email Configuration
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@dotvests.com
FRONTEND_URL=http://localhost:3000

# Admin Notifications Configuration
# Comma-separated list of admin emails to receive contact form notifications
ADMIN_EMAILS=contact@dotvests.com,admin@dotvests.com,support@dotvests.com
ADMIN_DASHBOARD_URL=https://dotvests.com/admin

# Waitlist Notifications Configuration
# Email to receive waitlist signup notifications
WAITLIST_NOTIFICATION_EMAIL=info@dotvests.com

# Paystack Payment Configuration
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key_here

# ZetaChain Blockchain Configuration
POLYMESH_NODE_URL=wss://testnet-rpc.polymesh.live
POLYMESH_ACCOUNT_URI=
POLYMESH_KEYSTORE_PATH=
POLYMESH_KEYSTORE_PASSWORD=
POLYMESH_VENUE_ID=

# Smile Identity KYC
SMILE_API_KEY=your_smile_api_key_here
SMILE_PARTNER_ID=your_smile_partner_id_here
SMILE_CALLBACK_URL=https://dotvests.com/api/kyc/webhook

# Database Configuration
# LOCAL DEVELOPMENT (SQLite - default)
# No configuration needed, database auto-creates at db/dotvests.db

# PRODUCTION (PostgreSQL on Render)
# Uncomment and set DATABASE_URL for production
# Format: postgresql://username:password@host:port/database
# Example: postgresql://user:password@db.render.com:5432/dotvests
# DATABASE_URL=your_postgresql_connection_string_here

# Environment
NODE_ENV=development
# Set to 'production' when deploying to Render
